{"id":"bcn_02","passos":[{"npc":{"id":"amiga","nom":"Amiga","frase":"Em truques demà?"},"escenari":"Una amiga et parla per telèfon.","pregunta":"Què substitueix 'em'?","opcions":[{"text":"A mi.","correcte":true,"feedback_ca":"Sí! Pronom feble de 1a persona.","feedback_es":"Sí! Pronombre débil de 1a persona.","seny":3,"rauxa":0,"coins":70},{"text":"A tu.","correcte":false,"feedback_ca":"No, 'et' seria a tu.","feedback_es":"No, 'te' sería a ti.","seny":0,"rauxa":1,"coins":0}]},{"npc":{"id":"botiguer","nom":"Botiguer","frase":"Vols el llibre? Te'l dono.","precise":"Vols el llibre? Te'l dono."},"escenari":"Un botiguer et ven un llibre.","pregunta":"Què vol dir 'te'l'?","opcions":[{"text":"Et dono el llibre.","correcte":true,"feedback_ca":"Correcte! 'te' + 'el' = te'l.","feedback_es":"Correcto! 'te' + 'lo' = te lo.","seny":3,"rauxa":0,"coins":75},{"text":"Et dono a tu.","correcte":false,"feedback_ca":"No, 'el' és el llibre.","feedback_es":"No, 'lo' es el libro.","seny":0,"rauxa":1,"coins":0}]},{"npc":{"id":"veí","nom":"Veí","frase":"Hi vas sovint al bar?","precise":"Hi vas sovint al bar?"},"escenari":"El veí et pregunta pel bar.","pregunta":"Què substitueix 'hi'?","opcions":[{"text":"Al bar.","correcte":true,"feedback_ca":"Sí! 'Hi' = a l'hi.","feedback_es":"Sí! 'Hi' = allí.","seny":3,"rauxa":0,"coins":80},{"text":"Res.","correcte":false,"feedback_ca":"No, 'hi' substitueix un lloc.","feedback_es":"No, 'hi' sustituye un lugar.","seny":0,"rauxa":1,"coins":0}]},{"npc":{"id":"noi","nom":"Noi","frase":"En tens de temps?","precise":"En tens de temps?"},"escenari":"Un noi et pregunta si tens temps.","pregunta":"Què substitueix 'en'?","opcions":[{"text":"De temps.","correcte":true,"feedback_ca":"Correcte! 'En' = de això.","feedback_es":"Correcto! 'En' = de ello.","seny":3,"rauxa":0,"coins":85},{"text":"Res.","correcte":false,"feedback_ca":"No, 'en' substitueix 'de + nom'.","feedback_es":"No, 'en' sustituye 'de + nombre'.","seny":0,"rauxa":1,"coins":0}]}]}
