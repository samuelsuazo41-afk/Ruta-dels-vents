{"id":"gir_02","passos":[{"npc":{"id":"guia","nom":"Guia","frase":"Aquesta és la muralla que van construir els romans."},"escenari":"Estàs a les muralles de Girona.","pregunta":"Quina funció té 'que'?","opcions":[{"text":"Relatiu que substitueix 'la muralla'.","correcte":true,"feedback_ca":"Exacte! 'Que' fa de complement directe.","feedback_es":"Exacto! 'Que' hace de complemento directo.","seny":3,"rauxa":0,"coins":65},{"text":"Conjunció causal.","correcte":false,"feedback_ca":"No, 'perquè' seria causal.","feedback_es":"No, 'porque' sería causal.","seny":0,"rauxa":1,"coins":0}]},{"npc":{"id":"turista","nom":"Turista","frase":"Busco algú qui parli anglès."},"escenari":"Un turista demana ajuda.","pregunta":"Per què 'qui' i no 'que'?","opcions":[{"text":"Perquè 'qui' es refereix a persones.","correcte":true,"feedback_ca":"Sí! 'Qui' per persones, 'que' per coses.","feedback_es":"Sí! 'Quien' para personas, 'que' para cosas.","seny":3,"rauxa":0,"coins":70},{"text":"Perquè sona millor.","correcte":false,"feedback_ca":"No és per estil, és gramàtica.","feedback_es":"No es por estilo, es gramática.","seny":0,"rauxa":1,"coins":0}]},{"npc":{"id":"local","nom":"Local","frase":"Aquest és el lloc on vaig néixer."},"escenari":"Un local et mostra la ciutat.","pregunta":"Què substitueix 'on'?","opcions":[{"text":"Un lloc.","correcte":true,"feedback_ca":"Correcte! 'On' = en el qual.","feedback_es":"Correcto! 'Donde' = en el cual.","seny":3,"rauxa":0,"coins":75},{"text":"Un temps.","correcte":false,"feedback_ca":"No, per temps usem 'quan'.","feedback_es":"No, para tiempo usamos 'cuando'.","seny":0,"rauxa":1,"coins":0}]},{"npc":{"id":"ancià","nom":"Ancià","frase":"Recordo el dia quan va caure la muralla.","precise":"Recordo el dia quan va caure la muralla."},"escenari":"Un ancià explica una història.","pregunta":"És correcte 'quan' aquí?","opcions":[{"text":"Sí, per referir-se a un moment.","correcte":true,"feedback_ca":"Sí! 'Quan' per moments temporals.","feedback_es":"Sí! 'Cuando' para momentos temporales.","seny":3,"rauxa":0,"coins":80},{"text":"No, hauria de ser 'que'.","correcte":false,"feedback_ca":"No, 'que' no indica temps.","feedback_es":"No, 'que' no indica tiempo.","seny":0,"rauxa":1,"coins":0}]}]}
